{
  "manifest_version": 3,
  "name": "catm",
  "short_name": "catm",
  "description": "On-device long-form text-to-speech in a side panel. Right-click selected text → Read it to me.",
  "version": "0.2.2",
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png",
    "512": "icons/icon-512.png"
  },
  "permissions": ["contextMenus", "storage", "sidePanel", "tabs"],
  "action": {
    "default_title": "Open catm side panel"
  },
  "side_panel": {
    "default_path": "app/index.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "cross_origin_opener_policy": { "value": "same-origin" },
  "cross_origin_embedder_policy": { "value": "require-corp" },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
