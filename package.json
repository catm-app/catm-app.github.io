{
  "name": "catm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "100% in-browser long-form text-to-speech reader, shipped as a Chrome extension. Kokoro 82M TTS via ONNX Runtime Web (WebGPU/WASM). No server.",
  "author": "Alain Brown",
  "license": "MIT",
  "homepage": "https://catm-app.github.io/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/catm-app/catm-app.github.io.git"
  },
  "bugs": {
    "url": "https://github.com/catm-app/catm-app.github.io/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build --mode extension",
    "preview": "vite preview",
    "lint": "biome check .",
    "check:marketing": "node scripts/check-marketing.mjs",
    "format": "biome format --write .",
    "test": "vitest run && npm run build && playwright test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "fflate": "^0.8.3",
    "hls.js": "^1.6.16",
    "idb": "^8.0.3",
    "kokoro-js": "^1.2.1",
    "mediabunny": "^1.45.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.49.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
