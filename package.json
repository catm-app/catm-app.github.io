{
  "name": "catm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "100% in-browser long-form text-to-speech reader. Kokoro 82M TTS via ONNX Runtime Web (WebGPU/WASM). Installable PWA, no server.",
  "author": "Alain Brown",
  "license": "MIT",
  "homepage": "https://catm-app.github.io/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/catm-app/catm-app.github.io.git"
  },
  "bugs": {
    "url": "https://github.com/catm-app/catm-app.github.io/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:ext": "tsc -b && vite build --mode extension",
    "build:all": "npm run build && npm run build:ext",
    "preview": "vite preview",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "fflate": "^0.8.3",
    "hls.js": "^1.6.16",
    "idb": "^8.0.3",
    "kokoro-js": "^1.2.1",
    "mp4-muxer": "^5.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.49.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  }
}
